{
  "name": "cimg-cf",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "fuser -k 11000/tcp 11001/tcp || true && vite --host 0.0.0.0 --port 11000 & wait-on tcp:11000 && npx wrangler pages dev --proxy 11000 --port 11001 --ip 0.0.0.0",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "npm run build && wrangler pages dev",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "deploy": "npm run build && wrangler pages deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@tanstack/vue-query": "^5.101.2",
    "jose": "^6.2.3",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@cloudflare/workers-types": "^5.20260721.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "npm-run-all2": "^9.0.2",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vue-tsc": "^3.3.5",
    "wait-on": "^9.0.10",
    "wrangler": "^4.104.0"
  },
  "engines": {
    "node": "^22.18.0 || >=24.12.0"
  }
}
